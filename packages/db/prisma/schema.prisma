generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
  CUSTOMER

  @@map("roles")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("booking_statuses")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED

  @@map("invoice_statuses")
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  ONLINE

  @@map("payment_methods")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED

  @@map("payment_statuses")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  role           Role     @default(CUSTOMER)
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@map("users")
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  role      Role     @default(EMPLOYEE)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@map("staff")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @default(0)
  duration    Int      @default(60) // minutes
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]

  @@map("services")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
  invoices Invoice[]

  @@map("customers")
}

model Booking {
  id         String        @id @default(cuid())
  customerId String
  serviceId  String
  staffId    String?
  date       DateTime      @db.Date
  time       String // HH:MM format
  status     BookingStatus @default(PENDING)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff    Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@map("bookings")
}

model Invoice {
  id        String        @id @default(cuid())
  customerId String
  amount    Decimal
  status    InvoiceStatus @default(DRAFT)
  dueDate   DateTime      @db.Date
  paidDate  DateTime?     @db.Date
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("invoices")
}

model Payment {
  id        String        @id @default(cuid())
  invoiceId String
  amount    Decimal
  method    PaymentMethod @default(CASH)
  status    PaymentStatus @default(PENDING)
  date      DateTime      @default(now())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  description String?
  organizationId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@map("companies")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users    User[]
  companies Company[]

  @@map("organizations")
}
